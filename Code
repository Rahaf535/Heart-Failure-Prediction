from sklearn.neighbors import KNeighborsClassifier
from sklearn.model_selection import GridSearchCV, train_test_split
from sklearn.metrics import accuracy_score, confusion_matrix, roc_auc_score, roc_curve
import matplotlib.pyplot as plt
import seaborn as sns

# 1. تقسيم البيانات
X_train, X_test, y_train, y_test = train_test_split(X_encoded_df, y, test_size=0.2, random_state=42)

# 2. تحديد القيم التي نريد تجربتها للـ K
param_grid = {
    'n_neighbors': [3, 5, 7, 9, 11],
    'weights': ['uniform', 'distance'],
    'metric': ['euclidean', 'manhattan']
}

# 3. إنشاء النموذج الأساسي وتطبيق GridSearchCV
knn = KNeighborsClassifier()
grid = GridSearchCV(knn, param_grid, cv=5, scoring='accuracy', verbose=1)
grid.fit(X_train, y_train)

# 4. أفضل نموذج تم إيجاده
best_knn = grid.best_estimator_
print("✅ أفضل إعدادات:", grid.best_params_)
print("🎯 أفضل دقة في التدريب (CV):", grid.best_score_)

# 5. التنبؤ على بيانات الاختبار
y_pred = best_knn.predict(X_test)

# ⚠️ KNN ما يدعم predict_proba في حال `weights='uniform'` + بعض المعايير
# نتأكد قبل استخدامها:
if hasattr(best_knn, "predict_proba"):
    y_proba = best_knn.predict_proba(X_test)[:, 1]
else:
    y_proba = [0.5 if pred == 1 else 0.5 for pred in y_pred]  # تخمين وسط لتجنب كسر الكود

# 6. تقييم الدقة
acc = accuracy_score(y_test, y_pred)
print(f"🎯 Accuracy على بيانات الاختبار: {acc:.3f}")

# 7. مصفوفة الالتباس
cm = confusion_matrix(y_test, y_pred)
plt.figure(figsize=(5, 4))
sns.heatmap(cm, annot=True, fmt="d", cmap="Greens")
plt.title("KNN Confusion Matrix")
plt.xlabel("Predicted")
plt.ylabel("Actual")
plt.show()

# 8. منحنى ROC و AUC (إذا ممكن)
try:
    auc_score = roc_auc_score(y_test, y_proba)
    fpr, tpr, _ = roc_curve(y_test, y_proba)

    plt.figure()
    plt.plot(fpr, tpr, label=f"AUC = {auc_score:.3f}")
    plt.plot([0, 1], [0, 1], 'k--')
    plt.title("KNN ROC Curve")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.legend()
    plt.grid(True)
    plt.show()
except:
    print("⚠️ لم يمكن حساب AUC لأن النموذج لا يدعم الاحتمالات في هذا الإعداد.")
