from sklearn.preprocessing import OneHotEncoder, OrdinalEncoder
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler

# تحديد الأعمدة حسب نوعها
target = 'HeartDisease'
X = df.drop(columns=[target])
y = df[target]

nominal_features = ['Sex', 'ChestPainType', 'RestingECG', 'ExerciseAngina']
ordinal_features = ['ST_Slope']
numeric_features = X.select_dtypes(include=['int64', 'float64']).columns.difference([target])

# ترتيب القيم لفئة ST_Slope (Up < Flat < Down)
ordinal_order = [['Up', 'Flat', 'Down']]

# إنشاء ColumnTransformer
preprocessor = ColumnTransformer(
    transformers=[
        ('num', StandardScaler(), numeric_features),
        ('nom', OneHotEncoder(drop='first'), nominal_features),
        ('ord', OrdinalEncoder(categories=ordinal_order), ordinal_features)
    ]
)

# تطبيق المعالجة
X_encoded = preprocessor.fit_transform(X)

# تحويل الناتج إلى DataFrame
encoded_feature_names = (
    list(numeric_features) +
    list(preprocessor.named_transformers_['nom'].get_feature_names_out(nominal_features)) +
    ordinal_features
)

X_encoded_df = pd.DataFrame(X_encoded, columns=encoded_feature_names)

# عرض أول 5 صفوف من البيانات المشفرة
print(" البيانات بعد الترميز:")
