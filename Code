        elif (col1 in num_cols) and (col2 in num_cols):
            # عددي × عددي
            corr = df[[col1, col2]].corr(method='pearson').iloc[0,1]
            full_corr.loc[col1, col2] = corr
        elif (col1 in cat_cols) and (col2 in cat_cols):
            # فئوي × فئوي
            confusion = pd.crosstab(df[col1], df[col2])
            corr = cramers_v(confusion)
            full_corr.loc[col1, col2] = corr
        else:
            # عددي × فئوي أو فئوي × عددي
            num_var = col1 if col1 in num_cols else col2
            cat_var = col2 if col1 in num_cols else col1
            corr = correlation_ratio(df[cat_var], df[num_var])
            full_corr.loc[col1, col2] = corr

